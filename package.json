{
	"name": "",
	"version": "1.0.0",
	"main": "dist/index.js",
	"author": "@sapphire",
	"license": "UNLICENSE",
	"type": "commonjs",
	"dependencies": {
		"@sapphire/decorators": "6.2.0",
		"@sapphire/discord.js-utilities": "7.3.3",
		"@sapphire/framework": "5.5.0",
		"@sapphire/plugin-logger": "4.1.0",
		"@sapphire/utilities": "3.18.2",
		"@skyra/env-utilities": "2.0.1",
		"colorette": "2.0.20",
		"discord.js": "14.26.4"
	},
	"devDependencies": {
		"@sapphire/cli": "1.9.3",
		"@sapphire/prettier-config": "2.0.0",
		"@sapphire/ts-config": "5.0.3",
		"@types/node": "26.0.0",
		"@types/ws": "8.18.1",
		"commitizen": "4.3.2",
		"cz-emoji": "1.3.2-canary.2",
		"prettier": "3.8.4",
		"tsc-watch": "7.2.0",
		"typescript": "6.0.3"
	},
	"scripts": {
		"sapphire": "sapphire",
		"generate": "sapphire generate",
		"build": "tsc",
		"watch": "tsc -w",
		"start": "node dist/index.js",
		"dev": "bun run build && bun run start",
		"watch:start": "tsc-watch --onSuccess \"bun run start\"",
		"format": "prettier --write \"src/\""
	},
	"prettier": "@sapphire/prettier-config",
	"config": {
		"commitizen": {
			"path": "cz-emoji"
		},
		"cz-emoji": {
			"skipQuestions": [
				"scope",
				"body",
				"issues",
				"breaking"
			]
		}
	}
}
